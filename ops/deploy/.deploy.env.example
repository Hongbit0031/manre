# Copy this file to ops/deploy/.deploy.env before the first deployment.

DEPLOY_GIT_BRANCH=main
DEPLOY_BASE_DIR=/srv/manre

BACKEND_SERVICE_NAME=manre-backend
BACKEND_JAR_NAME=linfeng-community-backend.jar
BACKEND_PORT=8080
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=prod

MYSQL_URL=jdbc:mysql://127.0.0.1:3306/linfengcommunity?useUnicode=true&characterEncoding=UTF-8&serverTimezone=Asia/Shanghai&useSSL=false
MYSQL_USERNAME=linfengcommunity
MYSQL_PASSWORD=change-me

REDIS_OPEN=true
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

MAIL_HOST=smtp.qq.com
MAIL_USERNAME=111111@qq.com
MAIL_PASSWORD=change-me
MAIL_SEND_FROM=111111@qq.com

MINIO_ENDPOINT=http://127.0.0.1:9005
MINIO_ACCESS_KEY=linfeng01
MINIO_SECRET_KEY=minio123
MINIO_BUCKET_NAME=linfeng

LINFENG_IMAGE_PATH=/data/linfeng/image/
LINFENG_VIDEO_PATH=/data/linfeng/video/
LINFENG_FILE_PATH=/data/linfeng/file/

THIRDLOGIN_OPEN=false
THIRDLOGIN_SECRET=change-me
KNIFE4J_ENABLE=false
KNIFE4J_BASIC_ENABLE=false
KNIFE4J_USERNAME=linfengcommunity
KNIFE4J_PASSWORD=linfengcommunity
SWAGGER_BASIC_ENABLE=true
SWAGGER_BASIC_USERNAME=linfengcommunity
SWAGGER_BASIC_PASSWORD=linfengcommunity

ADMIN_SITE_DIR=/var/www/manre-admin
ADMIN_PUBLIC_DEV_API=http://127.0.0.1:8080
ADMIN_PUBLIC_PROD_API=https://api.example.com
ADMIN_NODE_INSTALL_CMD=npm ci

UNI_H5_ENABLED=1
UNI_H5_SITE_DIR=/var/www/manre-h5
UNI_H5_BUILD_CMD=
UNI_H5_OUTPUT_DIR=/Users/replace-me/manre/linfeng-community-uniapp/unpackage/dist/build/h5
UNI_H5_BASE_URL=api.example.com
UNI_H5_API_PROTOCOL=https
UNI_H5_WS_PROTOCOL=wss
UNI_H5_SHARE_URL=https://h5.example.com/#/
UNI_H5_EMOJI_URL=https://h5.example.com/static/emoji/
UNI_H5_IMG_RESOURCE=https://h5.example.com/resource
UNI_H5_WX_MP_APP_ID=
UNI_H5_WX_H5_LOGIN=false

NGINX_SERVER_NAME=example.com
NGINX_ADMIN_SERVER_NAME=admin.example.com
NGINX_ADMIN_ROOT=/var/www/manre-admin
NGINX_UNI_H5_ROOT=/var/www/manre-h5
NGINX_API_UPSTREAM=http://127.0.0.1:8080
NGINX_CONF_PATH=/etc/nginx/conf.d/manre.conf

INSTALL_SYSTEMD=1
INSTALL_NGINX=1
